# Copy to `edge-secrets.local.env` in the repository root and fill in values.
# That file is not committed. Then run: `npm run edge-secrets:push`
#
# Slack (most notification functions)
SLACK_BOT_TOKEN=

# Optional channel overrides
APP_FIX_SLACK_CHANNEL=
MEDALERT_CHANNEL=
RETENTION_TEAM_SLACK_CHANNEL=
RETENTION_BUFFER_SLACK_CHANNEL=

# Portal links in Slack messages
PORTAL_BASE_URL=

# Jotform (submit-to-jotform)
JOTFORM_API_KEY=
JOTFORM_FORM_ID=

# DNC screening (dnc-lookup) — at least one provider pair is required for full behaviour
REALVALIDITO_API_KEY=
REALVALIDITO_API_SECRET=
BLACKLIST_ALLIANCE_API_KEY=

# transfer-check + NOTIFY_ELIGIBLE_AGENTS — if unset, the sync script derives these from .env.
# Prefer the legacy anon JWT for SUPABASE_ANON_KEY (Dashboard → API → anon public).
EDGE_SUPABASE_ANON_KEY=

# Override notify-eligible-agents target (defaults to this project’s function URL + publishable/anon from .env)
NOTIFY_ELIGIBLE_AGENTS_URL=
NOTIFY_ELIGIBLE_AGENTS_ANON_KEY=
